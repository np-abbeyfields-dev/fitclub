generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  displayName  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ClubMemberships   ClubMembership[]
  TeamMemberships   TeamMembership[]
  TeamsCreated      Team[]           @relation("TeamCreatedBy")
  Workouts          Workout[]
  ScoreLedgers      ScoreLedger[]
  PushTokens        PushToken[]

  @@index([email])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   // Expo push token (e.g. ExponentPushToken[...])
  platform  String?  // ios | android
  createdAt DateTime @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
}

model Club {
  id          String   @id @default(uuid())
  name        String
  inviteCode  String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  Memberships ClubMembership[]
  Rounds      Round[]

  @@index([inviteCode])
}

enum ClubRole {
  admin
  team_lead
  member
  @@map("club_role")
}

enum RoundStatus {
  draft
  active
  completed
  @@map("round_status")
}

// A user can be part of multiple clubs (multiple ClubMembership rows per userId).
// @@unique([userId, clubId]) ensures at most one membership per user per club.
model ClubMembership {
  id        String   @id @default(uuid())
  userId    String
  clubId    String
  role      ClubRole @default(member)
  joinedAt  DateTime @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)
  Club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([userId])
  @@index([clubId])
}

// One club → one active round. DB: partial unique index Round_clubId_status_active_key on (clubId) WHERE status = 'active'.
model Round {
  id              String      @id @default(uuid())
  clubId          String
  name            String
  startDate       DateTime
  endDate         DateTime
  scoringConfig   Json        // RoundScoringConfig per FITCLUB_SCORING_ENGINE_SPEC
  teamSize        Int?
  locked          Boolean     @default(false)
  status          RoundStatus @default(draft)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  Club  Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  Teams Team[]
  Workouts     Workout[]
  ScoreLedgers ScoreLedger[]
  TeamMemberships TeamMembership[]

  @@index([clubId])
  @@index([startDate, endDate])
  @@index([clubId, status])
}

model Team {
  id        String   @id @default(uuid())
  roundId   String
  name      String
  createdBy String?
  createdAt DateTime @default(now())

  Round        Round            @relation(fields: [roundId], references: [id], onDelete: Cascade)
  CreatedByUser User?           @relation("TeamCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  Memberships  TeamMembership[]
  ScoreLedgers ScoreLedger[]

  @@index([roundId])
  @@index([createdBy])
}

// One user → one team per round. DB: unique index TeamMembership_userId_roundId_key on (userId, roundId).
model TeamMembership {
  id        String   @id @default(uuid())
  userId    String
  teamId    String
  roundId   String
  joinedAt  DateTime @default(now())
  isLeader  Boolean  @default(false)

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  Round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@unique([userId, roundId]) // unique(roundId, userId) — one team per user per round
  @@index([userId])
  @@index([teamId])
  @@index([roundId])
}

model Workout {
  id               String   @id @default(uuid())
  userId           String
  roundId          String
  activityType     String
  workoutMasterId Int?
  durationMinutes  Int?
  distanceKm       Float?
  proofUrl         String?
  notes            String?
  loggedAt         DateTime
  createdAt        DateTime @default(now())

  User          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  Round         Round         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  WorkoutMaster WorkoutMaster? @relation(fields: [workoutMasterId], references: [id], onDelete: SetNull)
  ScoreLedger   ScoreLedger?

  @@index([userId])
  @@index([roundId])
  @@index([loggedAt])
  @@index([workoutMasterId])
}

model ScoreLedger {
  id                   String   @id @default(uuid())
  workoutId            String   @unique
  userId               String
  roundId              String
  teamId               String?
  reasonType           String   @default("workout") // workout | adjustment | admin_override
  rawPoints            Float
  cappedPoints         Float
  dailyAdjustedPoints  Float
  finalAwardedPoints   Float
  ruleSnapshotJson     String?
  createdAt            DateTime @default(now())

  Workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  User    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  Round   Round   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  Team    Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([roundId])
  @@index([teamId])
  @@index([createdAt])
}

// Precomputed stats per user per round (FITCLUB_MASTER_SPEC §5.10). Updated on workout write.
model UserStats {
  id            String   @id @default(uuid())
  userId        String
  clubId        String
  roundId       String
  totalPoints   Float    @default(0)
  totalWorkouts Int      @default(0)
  totalCalories Float    @default(0)
  streakDays    Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([userId, clubId, roundId])
  @@index([userId])
  @@index([roundId])
  @@index([clubId])
  @@map("user_stats")
}

// Precomputed stats per team per round (FITCLUB_MASTER_SPEC §5.11). Updated on workout write.
model TeamStats {
  id          String   @id @default(uuid())
  teamId      String
  clubId      String
  roundId     String
  totalPoints Float    @default(0)
  totalWorkouts Int    @default(0)
  memberCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([teamId, roundId])
  @@index([teamId])
  @@index([roundId])
  @@index([clubId])
  @@map("team_stats")
}

// Activity feed for club (FITCLUB_MASTER_SPEC §5.12). Scaffold for V2.
model ActivityFeed {
  id           String   @id @default(uuid())
  clubId       String
  actorUserId  String
  type         String   // WORKOUT_LOGGED, STREAK_REACHED, ROUND_STARTED, TEAM_JOINED, TEAM_CREATED, MILESTONE_REACHED
  metadataJson String?  // JSON payload
  createdAt    DateTime @default(now())

  @@index([clubId])
  @@index([createdAt])
  @@map("activity_feed")
}

// In-app notifications (FITCLUB_MASTER_SPEC §5.13).
model Notification {
  id        String    @id @default(uuid())
  userId    String
  clubId    String?
  type      String
  title     String
  body      String
  isRead    Boolean   @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// Reference data: generic workout types with MET/scoring parameters
model GenericWorkoutMet {
  id             Int     @id @default(autoincrement())
  workoutType    String  @unique @map("workout_type")
  avgMetPerHour  Float?  @map("avg_met_per_hour")
  minMet         Float?  @map("min_met")
  maxMet         Float?  @map("max_met")
  mlp            Float?  @map("mlp")
  maxMetLimit    Float?  @map("max_met_limit")
  metCap         Float?  @map("met_cap")

  workoutMasters WorkoutMaster[]

  @@map("generic_workout_met")
}

// Maps specific workout type names to generic workout categories
model WorkoutMaster {
  id                 Int               @id @default(autoincrement())
  workoutType        String            @unique
  genericWorkoutType String
  genericWorkout     GenericWorkoutMet @relation(fields: [genericWorkoutType], references: [workoutType])
  workouts           Workout[]

  @@map("WorkoutMaster")
}
