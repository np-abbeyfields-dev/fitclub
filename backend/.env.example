# FitClub API - copy to .env and fill values
# GCP project (Cloud Run + Cloud SQL): fitclub-488901
#
# For local dev with Cloud SQL proxy, run:
#   cd backend/scripts && ./setup-local-cloud-sql-env.sh
# That will set DATABASE_URL and JWT_SECRET.

NODE_ENV=development
PORT=8080

# Cloud SQL via proxy (local dev) - or use setup-local-cloud-sql-env.sh
# DATABASE_URL=postgresql://fitclub_user:YOUR_PASSWORD@127.0.0.1:5433/fitclub?schema=public

# Local Postgres (alternative, no Cloud SQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/fitclub

# JWT (setup script can generate; use strong secret in production)
JWT_SECRET=your-jwt-secret-change-in-production

# CORS (comma-separated origins or * for dev)
CORS_ORIGIN=*

# GCP
GCP_PROJECT_ID=fitclub-488901

# Optional: Resend (invite-by-email, Report Bug, Contact Us)
# RESEND_API_KEY=re_xxxx
# INVITE_FROM_EMAIL=FitClub <noreply@yourdomain.com>
# INVITE_APP_URL=https://yourapp.com
# SUPPORT_EMAIL=support@yourdomain.com

# Optional: Cron (internal endpoints: activate-scheduled-rounds, import-mmr-workouts)
# CRON_SECRET=your-cron-secret

# BETA_MMR: Temporary. Remove when dropping MMR sync.
# MMR_API_KEY=your-mmr-api-key
# MMR_BEARER_TOKEN=your-mmr-bearer-token
# MMR_USER_MAP=[{"email":"user@example.com","mmrUserId":"12345"}]
# MMR_CLUB_ID=optional-club-uuid
# MMR_IMPORT_DAYS=90
