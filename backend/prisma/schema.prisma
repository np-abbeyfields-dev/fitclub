generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  displayName  String
  weight       Float?   // kg; used for caloriesBurned = MET × weight × durationMinutes × 0.0175
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ClubMemberships        ClubMembership[]
  TeamMemberships        TeamMembership[]
  TeamsCreated           Team[]                 @relation("TeamCreatedBy")
  Workouts               Workout[]
  ScoreLedgers           ScoreLedger[]
  PushTokens              PushToken[]
  CustomChallengesCreated CustomChallenge[]      @relation("CustomChallengeCreatedBy")
  CustomChallengeCompletions CustomChallengeCompletion[]

  @@index([email])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   // Expo push token (e.g. ExponentPushToken[...])
  platform  String?  // ios | android
  createdAt DateTime @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
}

model Club {
  id          String   @id @default(uuid())
  name        String
  inviteCode  String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  Memberships         ClubMembership[]
  Rounds              Round[]
  ChallengesCreated   Challenge[]             @relation("ChallengeCreatedBy")
  ChallengeParticipations ChallengeParticipant[]
  CustomChallenges    CustomChallenge[]

  @@index([inviteCode])
}

enum ClubRole {
  admin
  team_lead
  member
  @@map("club_role")
}

enum RoundStatus {
  draft
  active
  completed
  @@map("round_status")
}

enum ChallengeStatus {
  draft
  active
  completed
  @@map("challenge_status")
}

// A user can be part of multiple clubs (multiple ClubMembership rows per userId).
// @@unique([userId, clubId]) ensures at most one membership per user per club.
model ClubMembership {
  id        String   @id @default(uuid())
  userId    String
  clubId    String
  role      ClubRole @default(member)
  joinedAt  DateTime @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)
  Club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([userId])
  @@index([clubId])
}

// One club → one active round. DB: partial unique index Round_clubId_status_active_key on (clubId) WHERE status = 'active'.
model Round {
  id                String      @id @default(uuid())
  clubId            String
  name              String
  startDate         DateTime
  endDate           DateTime
  scoringConfig     Json        // RoundScoringConfig per FITCLUB_SCORING_ENGINE_SPEC
  teamSize          Int?
  locked            Boolean     @default(false)
  status            RoundStatus @default(draft)
  scheduledStartAt  DateTime?   @map("scheduled_start_at") // When set, batch job sets status to active at this time
  draftPickIndex    Int         @default(0) @map("draft_pick_index") // Snake draft: current global pick (0-based); incremented after each pick
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  Club  Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  Teams Team[]
  Workouts     Workout[]
  ScoreLedgers ScoreLedger[]
  TeamMemberships TeamMembership[]
  ChallengeParticipation ChallengeParticipant? @relation("RoundChallengeParticipation")
  CustomChallengeCompletions CustomChallengeCompletion[]
  CustomChallenges CustomChallenge[]

  @@index([clubId])
  @@index([startDate, endDate])
  @@index([clubId, status])
}

// Inter-club challenge: links two (or N) clubs; each club designates one round for the challenge.
model Challenge {
  id              String          @id @default(uuid())
  name            String
  startDate       DateTime
  endDate         DateTime
  status          ChallengeStatus @default(draft)
  createdByClubId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  CreatedByClub Club?                  @relation("ChallengeCreatedBy", fields: [createdByClubId], references: [id], onDelete: SetNull)
  Participants  ChallengeParticipant[]

  @@index([createdByClubId])
  @@index([status])
}

model ChallengeParticipant {
  id          String   @id @default(uuid())
  challengeId String
  clubId      String
  roundId     String?  // round this club uses for this challenge (set when club assigns a round)
  joinedAt    DateTime @default(now())

  Challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  Club      Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  Round     Round?    @relation("RoundChallengeParticipation", fields: [roundId], references: [id], onDelete: SetNull)

  @@unique([challengeId, clubId])
  @@unique([roundId])  // a round can be used in at most one challenge
  @@index([challengeId])
  @@index([clubId])
}

// Round-scoped habit-style challenges (e.g. "Drink 6 glasses of water"). One round has many; each challenge ends with the round.
model CustomChallenge {
  id              String   @id @default(uuid())
  roundId         String   @map("round_id")
  clubId          String   @map("club_id")
  name            String
  description     String?
  icon            String?  // e.g. Ionicons name
  pointsAwarded   Int      @map("points_awarded")
  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  Round   Round   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  Club    Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  CreatedByUser User @relation("CustomChallengeCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  Completions CustomChallengeCompletion[]

  @@index([roundId])
  @@index([clubId])
  @@index([createdByUserId])
  @@map("custom_challenge")
}

// One completion per user per custom challenge per calendar day; points apply to the round at completion time.
model CustomChallengeCompletion {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  customChallengeId String   @map("custom_challenge_id")
  roundId           String   @map("round_id")
  completionDate    String   @map("completion_date") // YYYY-MM-DD (UTC calendar day)
  pointsAwarded     Int      @map("points_awarded")
  createdAt         DateTime @default(now())

  User            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  CustomChallenge CustomChallenge @relation(fields: [customChallengeId], references: [id], onDelete: Cascade)
  Round           Round           @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([customChallengeId, userId, completionDate])
  @@index([roundId])
  @@index([userId])
  @@index([customChallengeId])
  @@map("custom_challenge_completion")
}

model Team {
  id        String   @id @default(uuid())
  roundId   String
  name      String
  createdBy String?
  createdAt DateTime @default(now())

  Round        Round            @relation(fields: [roundId], references: [id], onDelete: Cascade)
  CreatedByUser User?           @relation("TeamCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  Memberships  TeamMembership[]
  ScoreLedgers ScoreLedger[]

  @@index([roundId])
  @@index([createdBy])
}

// One user → one team per round. DB: unique index TeamMembership_userId_roundId_key on (userId, roundId).
model TeamMembership {
  id        String   @id @default(uuid())
  userId    String
  teamId    String
  roundId   String
  joinedAt  DateTime @default(now())
  isLeader  Boolean  @default(false)

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  Round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@unique([userId, roundId]) // unique(roundId, userId) — one team per user per round
  @@index([userId])
  @@index([teamId])
  @@index([roundId])
}

model Workout {
  id               String   @id @default(uuid())
  userId           String
  roundId          String
  activityType     String   // Denormalized from WorkoutMaster.workoutType for display; workoutMasterId is source of truth
  workoutMasterId Int?
  durationMinutes  Int?
  distanceKm       Float?
  heartRate        Int?
  caloriesBurned   Float?   // MET (from master) × user weight (kg) × durationMinutes × 0.0175
  proofUrl         String?
  notes            String?
  loggedAt         DateTime
  createdAt        DateTime @default(now())
  /// BETA_MMR: Temporary. Dedupe MMR imports; remove when dropping MMR sync.
  mmrWorkoutId     String?   @unique

  User          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  Round         Round         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  WorkoutMaster WorkoutMaster? @relation(fields: [workoutMasterId], references: [id], onDelete: SetNull)
  ScoreLedger   ScoreLedger?

  @@index([userId])
  @@index([roundId])
  @@index([loggedAt])
  @@index([workoutMasterId])
}

model ScoreLedger {
  id                   String   @id @default(uuid())
  workoutId            String   @unique
  userId               String
  roundId              String
  teamId               String?
  reasonType           String   @default("workout") // workout | adjustment | admin_override
  rawPoints            Float
  cappedPoints         Float
  dailyAdjustedPoints  Float
  finalAwardedPoints   Float
  ruleSnapshotJson     String?
  createdAt            DateTime @default(now())

  Workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  User    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  Round   Round   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  Team    Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([roundId])
  @@index([teamId])
  @@index([createdAt])
}

// Precomputed stats per user per round (FITCLUB_MASTER_SPEC §5.10). Updated on workout write.
model UserStats {
  id            String   @id @default(uuid())
  userId        String
  clubId        String
  roundId       String
  totalPoints   Float    @default(0)
  totalWorkouts Int      @default(0)
  totalCalories Float    @default(0)
  streakDays    Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([userId, clubId, roundId])
  @@index([userId])
  @@index([roundId])
  @@index([clubId])
  @@map("user_stats")
}

// Precomputed stats per team per round (FITCLUB_MASTER_SPEC §5.11). Updated on workout write.
model TeamStats {
  id          String   @id @default(uuid())
  teamId      String
  clubId      String
  roundId     String
  totalPoints Float    @default(0)
  totalWorkouts Int    @default(0)
  memberCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([teamId, roundId])
  @@index([teamId])
  @@index([roundId])
  @@index([clubId])
  @@map("team_stats")
}

// Activity feed for club (FITCLUB_MASTER_SPEC §5.12). Scaffold for V2.
model ActivityFeed {
  id           String   @id @default(uuid())
  clubId       String
  actorUserId  String
  type         String   // WORKOUT_LOGGED, STREAK_REACHED, ROUND_STARTED, TEAM_JOINED, TEAM_CREATED, MILESTONE_REACHED
  metadataJson String?  // JSON payload
  createdAt    DateTime @default(now())

  @@index([clubId])
  @@index([createdAt])
  @@map("activity_feed")
}

// In-app notifications (FITCLUB_MASTER_SPEC §5.13).
model Notification {
  id        String    @id @default(uuid())
  userId    String
  clubId    String?
  type      String
  title     String
  body      String
  isRead    Boolean   @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// Reference data: generic workout types with MET/scoring parameters
model GenericWorkoutMet {
  id             Int     @id @default(autoincrement())
  workoutType    String  @unique @map("workout_type")
  avgMetPerHour  Float?  @map("avg_met_per_hour")
  minMet         Float?  @map("min_met")
  maxMet         Float?  @map("max_met")
  mlp            Float?  @map("mlp")
  maxMetLimit    Float?  @map("max_met_limit")
  metCap         Float?  @map("met_cap")

  workoutMasters WorkoutMaster[]

  @@map("generic_workout_met")
}

// Maps specific workout type names to generic workout categories
model WorkoutMaster {
  id                 Int               @id @default(autoincrement())
  workoutType        String            @unique
  genericWorkoutType String
  met                Float?            // MET value; caloriesBurned = met × user.weight × durationMinutes × 0.0175
  genericWorkout     GenericWorkoutMet @relation(fields: [genericWorkoutType], references: [workoutType])
  workouts           Workout[]

  @@map("WorkoutMaster")
}
