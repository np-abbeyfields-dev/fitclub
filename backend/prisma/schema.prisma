generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  displayName  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ClubMemberships ClubMembership[]
  TeamMemberships TeamMembership[]
  Workouts        Workout[]
  ScoreLedgers    ScoreLedger[]
  PushTokens      PushToken[]

  @@index([email])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   // Expo push token (e.g. ExponentPushToken[...])
  platform  String?  // ios | android
  createdAt DateTime @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
}

model Club {
  id          String   @id @default(uuid())
  name        String
  inviteCode  String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  Memberships ClubMembership[]
  Rounds      Round[]

  @@index([inviteCode])
}

enum ClubRole {
  admin
  team_lead
  member
  @@map("club_role")
}

enum RoundStatus {
  draft
  active
  ended
  @@map("round_status")
}

// A user can be part of multiple clubs (multiple ClubMembership rows per userId).
// @@unique([userId, clubId]) ensures at most one membership per user per club.
model ClubMembership {
  id        String   @id @default(uuid())
  userId    String
  clubId    String
  role      ClubRole @default(member)
  joinedAt  DateTime @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)
  Club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([userId])
  @@index([clubId])
}

model Round {
  id              String      @id @default(uuid())
  clubId          String
  name            String
  startDate       DateTime
  endDate         DateTime
  scoringConfig   Json        // RoundScoringConfig per FITCLUB_SCORING_ENGINE_SPEC
  teamSize        Int?
  locked          Boolean     @default(false)
  status          RoundStatus @default(draft)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  Club  Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  Teams Team[]
  Workouts     Workout[]
  ScoreLedgers ScoreLedger[]
  TeamMemberships TeamMembership[]

  @@index([clubId])
  @@index([startDate, endDate])
  @@index([clubId, status])
}

model Team {
  id        String   @id @default(uuid())
  roundId   String
  name      String
  createdAt DateTime @default(now())

  Round       Round            @relation(fields: [roundId], references: [id], onDelete: Cascade)
  Memberships TeamMembership[]

  @@index([roundId])
}

// Business rules (enforced in DB + TeamService):
// - A user can be in multiple clubs and, within a club, in multiple teams across different rounds.
// - A user can be in only ONE team per club per round (enforced by @@unique([userId, roundId])).
// - Historically a user may have been on different teams in the same club (different rounds).
model TeamMembership {
  id        String   @id @default(uuid())
  userId    String
  teamId    String
  roundId   String

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  Round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@unique([userId, roundId]) // One team per user per round (per club, since round belongs to club).
  @@index([userId])
  @@index([teamId])
  @@index([roundId])
}

model Workout {
  id             String   @id @default(uuid())
  userId         String
  roundId        String
  activityType   String
  durationMinutes Int?
  distanceKm     Float?
  proofUrl       String?
  loggedAt       DateTime
  createdAt      DateTime @default(now())

  User         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  Round        Round        @relation(fields: [roundId], references: [id], onDelete: Cascade)
  ScoreLedger  ScoreLedger?

  @@index([userId])
  @@index([roundId])
  @@index([loggedAt])
}

model ScoreLedger {
  id                   String   @id @default(uuid())
  workoutId            String   @unique
  userId               String
  roundId              String
  rawPoints            Float
  cappedPoints         Float
  dailyAdjustedPoints  Float
  finalAwardedPoints   Float
  ruleSnapshotJson     String?
  createdAt            DateTime @default(now())

  Workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  User    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  Round   Round   @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roundId])
  @@index([createdAt])
}

// Reference data: generic workout types with MET/scoring parameters
model GenericWorkoutMet {
  id             Int     @id @default(autoincrement())
  workoutType    String  @unique @map("workout_type")
  avgMetPerHour  Float?  @map("avg_met_per_hour")
  minMet         Float?  @map("min_met")
  maxMet         Float?  @map("max_met")
  mlp            Float?  @map("mlp")
  maxMetLimit    Float?  @map("max_met_limit")
  metCap         Float?  @map("met_cap")

  workoutMasters WorkoutMaster[]

  @@map("generic_workout_met")
}

// Maps specific workout type names to generic workout categories
model WorkoutMaster {
  id                 Int               @id @default(autoincrement())
  workoutType        String            @unique
  genericWorkoutType String
  genericWorkout     GenericWorkoutMet @relation(fields: [genericWorkoutType], references: [workoutType])

  @@map("WorkoutMaster")
}
