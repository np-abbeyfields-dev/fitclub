# API base URL (no trailing slash). Used by the app for auth and clubs.
# Leave unset to use local backend: http://127.0.0.1:8080/api

# Cloud Run (replace with your service URL from: gcloud run services describe fitclub-api --region=us-west1 --project=fitclub-488901 --format='value(status.url)')
# EXPO_PUBLIC_API_URL=https://fitclub-api-xxxxx.run.app/api

# Optional: override local backend host (when EXPO_PUBLIC_API_URL is not set)
# EXPO_PUBLIC_LOCAL_IP=127.0.0.1
